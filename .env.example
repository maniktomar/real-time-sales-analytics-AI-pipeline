# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SALES_TOPIC=sales-transactions
KAFKA_LOG_TOPIC=application-logs
PRODUCER_EVENTS_PER_SECOND=5

# Spark
SPARK_APP_NAME=RealTimeSalesPipeline
SPARK_CHECKPOINT_BASE=./checkpoints

# Snowflake
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=REALTIME_ANALYTICS
SNOWFLAKE_SCHEMA=CURATED
SNOWFLAKE_URL=your_account.snowflakecomputing.com

# Optional REST API
API_HOST=0.0.0.0
API_PORT=8000

